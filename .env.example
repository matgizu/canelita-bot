# WhatsApp Cloud API (Meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=mi_token_de_verificacion

# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/canelita?schema=public"

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (solo para transcripción de audios con Whisper)
OPENAI_API_KEY=

# Telegram (notificaciones)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Precios (COP)
PRICE_UNIT=69900
PRICE_2X=119900
PRICE_3X=159900

# Métodos de pago anticipado
NEQUI_NUMBER=
BANCOLOMBIA_ACCOUNT=
DAVIPLATA_NUMBER=

# Envío
SHIPPING_COST_DEFAULT=0

# ─── Dropi: notificaciones de estado de guía a clientes ───────────────────────
# Credenciales del panel de Dropi. Con 2FA (Google Authenticator), el bot hace el
# login por password, te pide el código de 6 dígitos por WhatsApp, y guarda el
# token real (~12h). Cuando vence, te vuelve a pedir el código automáticamente.
DROPI_EMAIL=
DROPI_PASSWORD=
DROPI_WHITE_BRAND_ID=1
# (Opcional / respaldo) Token pegado a mano desde el navegador. Si lo pones, tiene
# prioridad sobre el flujo 2FA. Consola de Dropi:
#   copy(JSON.parse(localStorage.DROPI_LoginResult).token)
DROPI_TOKEN=
# Enciende el poller. Empieza en false hasta sembrar y probar.
DROPI_TRACKING_ENABLED=false
# En false hace DRY-RUN (no envía, solo loguea). Ponlo en true cuando estés listo.
DROPI_SEND_ENABLED=false
DROPI_POLL_MINUTES=30
DROPI_LOOKBACK_DAYS=20
# Plantillas Meta aprobadas para clientes FUERA de la ventana de 24h.
# Deja vacío lo que no tengas: fuera de ventana sin plantilla solo se registra.
DROPI_TPL_SHIPPED=
DROPI_TPL_OUT_FOR_DELIVERY=
DROPI_TPL_DELIVERED=
DROPI_TPL_DELIVERY_ATTEMPT=
DROPI_TPL_PICKUP_OFFICE=
DROPI_TPL_LANG=es

# Imágenes que rotan en el greeting (URLs separadas por coma)
# Ejemplo Railway:
# GREETING_IMAGE_URLS=https://tu-app.railway.app/assets/testimonio1.webp,https://tu-app.railway.app/assets/testimonio2.webp
GREETING_IMAGE_URLS=

# Server
PORT=3000

# ffmpeg para transcodificar notas de voz del panel a OGG/Opus.
# Opcional: si no se define, usa el binario de ffmpeg-static (dev) o el del PATH.
# En Docker se setea a /usr/bin/ffmpeg (ffmpeg del sistema).
# FFMPEG_PATH=/usr/bin/ffmpeg
