generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id                Int       @id @default(autoincrement())
  waId              String    @unique
  customerName      String?
  fullName          String?
  phone             String?
  altPhone          String?
  idNumber          String?
  address           String?
  reference         String?
  city              String?
  department        String?
  email             String?
  adSource          String?
  adHeadline        String?
  ctwaClid          String?
  adHistory         Json      @default("[]")
  wabaId            String?
  labels            String[]  @default([])
  // Fecha/hora en que se aplicó cada etiqueta custom: { "nombre": "ISO" }.
  // Las etiquetas de estado (Saludo/Interés/Cerrado) NO viven aquí, viven en `state`.
  labelMeta         Json      @default("{}")
  windowExpired     Boolean   @default(false)
  discountOffered   Boolean   @default(false)
  state             String    @default("GREETING")
  automationEnabled Boolean   @default(true)
  strategy          String    @default("A")
  objectionCount    Int       @default(0)
  cart              Json      @default("[]")
  pendingOrder      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  // Fecha/hora exacta en que se cerró la venta (CLOSED). Se limpia al reabrir.
  closedAt          DateTime?
  lastInboundAt     DateTime  @default(now())
  lastOutboundAt    DateTime  @default(now())
  messages          Message[]
  orders            Order[]

  @@index([state])
  @@index([automationEnabled])
}

model Template {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  category        String   @default("MARKETING")
  language        String   @default("es")
  body            String   @db.Text
  metaId          String?
  status          String   @default("DRAFT")
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId Int
  direction      String
  type           String
  body           String       @db.Text
  rawState       String?
  mediaUrl       String?
  whatsappMsgId  String?
  objectionType  String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model Order {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
  cart           Json
  total          Int
  paymentMethod  String
  status         String       @default("PENDING")
  fullName       String?
  idNumber       String?
  email          String?
  address        String?
  city           String?
  department     String?
  altPhone       String?
  reference      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([conversationId])
}

model Reminder {
  id        Int      @id @default(autoincrement())
  waId      String
  note      String   @db.Text
  dueAt     DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sent, dueAt])
}

model BotConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Catálogo de etiquetas custom creadas por el dueño, para reutilizarlas y
// filtrar. Independiente del estado del embudo.
model Tag {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Catálogo de productos. Cada producto puede tener fotos y videos subidos
// desde el panel. Solo los productos activos (isActive=true) se usarán en
// la integración con el bot (pendiente de implementar).
model Product {
  id          Int            @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean        @default(false)
  config      Json           @default("{}")
  sortOrder   Int            @default(0)
  media       ProductMedia[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProductMedia {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  type      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// Espejo del estado de envío de cada pedido en Dropi. El poller consulta la API
// interna de Dropi, compara `stage` contra `lastNotifiedStage` y dispara el
// mensaje de WhatsApp solo cuando la ETAPA cambia (idempotencia). `dropiOrderId`
// es el id del pedido en Dropi (no el Order interno del bot).
model DropiShipment {
  id               Int       @id @default(autoincrement())
  dropiOrderId     Int       @unique
  shippingGuide    String?
  phone            String    // normalizado 57XXXXXXXXXX
  customerName     String?
  carrier          String?
  city             String?
  rateType         String?   // CON RECAUDO | SIN RECAUDO
  total            Int       @default(0)  // valor a recaudar (COD)
  profit           Int       @default(0)  // dropshipper_amount_to_win (utilidad si se entrega)
  shippingCost     Int       @default(0)  // flete (shipping_amount)
  status           String    // estado crudo actual de Dropi
  previousStatus   String?
  stage            String    // etapa derivada (ver statusMap.ts)
  lastNotifiedStage String?  // última etapa por la que SÍ se notificó al cliente
  lastAlertedStage String?   // última etapa por la que SÍ se alertó al dueño
  notifyCount      Int       @default(0)
  lastNotifiedAt   DateTime?
  statusChangedAt  DateTime? // updated_at de Dropi cuando cambió el estado
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([stage])
  @@index([phone])
}
