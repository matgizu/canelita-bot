generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id                Int       @id @default(autoincrement())
  waId              String    @unique
  customerName      String?
  fullName          String?
  phone             String?
  altPhone          String?
  idNumber          String?
  address           String?
  reference         String?
  city              String?
  department        String?
  email             String?
  adSource          String?
  adHeadline        String?
  ctwaClid          String?
  labels            String[]  @default([])
  windowExpired     Boolean   @default(false)
  state             String    @default("GREETING")
  automationEnabled Boolean   @default(true)
  objectionCount    Int       @default(0)
  cart              Json      @default("[]")
  pendingOrder      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastInboundAt     DateTime  @default(now())
  lastOutboundAt    DateTime  @default(now())
  messages          Message[]
  orders            Order[]

  @@index([state])
  @@index([automationEnabled])
}

model Template {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  category        String   @default("MARKETING")
  language        String   @default("es")
  body            String   @db.Text
  metaId          String?
  status          String   @default("DRAFT")
  rejectionReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model Message {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId Int
  direction      String
  type           String
  body           String       @db.Text
  rawState       String?
  mediaUrl       String?
  whatsappMsgId  String?
  objectionType  String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
}

model Order {
  id             Int          @id @default(autoincrement())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  conversationId Int
  cart           Json
  total          Int
  paymentMethod  String
  status         String       @default("PENDING")
  fullName       String?
  idNumber       String?
  email          String?
  address        String?
  city           String?
  department     String?
  altPhone       String?
  reference      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([conversationId])
}

model Reminder {
  id        Int      @id @default(autoincrement())
  waId      String
  note      String
  dueAt     DateTime
  sent      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([sent, dueAt])
}
