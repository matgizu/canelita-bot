{
  "name": "freskabox-bot",
  "version": "0.1.0",
  "description": "Bot WhatsApp para cajones organizadores extensibles FreskaBox",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "typecheck": "tsc --noEmit",
    "test": "for f in tests/*.test.ts; do tsx \"$f\" || exit 1; done",
    "sim": "tsx bin/sim.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.22.0",
    "@types/multer": "^2.1.0",
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "form-data": "^4.0.1",
    "multer": "^2.1.1",
    "openai": "^4.73.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
